VITE_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Google Ads Configuration  
VITE_GOOGLE_ADS_ID=AW-17324759362
VITE_GOOGLE_ADS_CONVERSION_ID=123456789

# Social Media
